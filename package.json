{
  "name": "easyvietsub",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "tauri:dev": "MACOSX_DEPLOYMENT_TARGET=10.15 tauri dev",
    "tauri:dev:macos": "MACOSX_DEPLOYMENT_TARGET=10.15 tauri dev -- --features enable-metal",
    "tauri:dev:windows:cuda": "tauri dev -- --features enable-cuda",
    "tauri:dev:windows:vulkan": "tauri dev -- --features enable-vulkan",
    "tauri:build:macos": "MACOSX_DEPLOYMENT_TARGET=10.15 tauri build -- --features enable-metal",
    "tauri:build:windows:cuda": "tauri build -- --features enable-cuda",
    "tauri:build:windows:vulkan": "tauri build -- --features enable-vulkan",
    "tauri:build:cpu": "tauri build",
    "sidecars:build": "sh ./scripts/build-sidecars.sh",
    "sidecars:build:windows": "pwsh -File ./scripts/build-sidecars.ps1"
  },
  "dependencies": {
    "@lucide/svelte": "^0.542.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tiptap/core": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "clsx": "^2.1.1",
    "svelte": "^5.0.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.3.1",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "bits-ui": "^2.16.3",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
